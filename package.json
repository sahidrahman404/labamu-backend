{
  "name": "backend",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "effect-language-service patch && husky",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.2",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "effect": "^3.21.0"
  }
}
